# verticalmedia configuration
# Copy this file to .env and fill in your values

# ━━━ qBittorrent (required) ━━━
QBIT_URL=http://localhost:8081
QBIT_USERNAME=admin
QBIT_PASSWORD=adminadmin

# ━━━ Prowlarr (optional) ━━━
# Adds all your configured indexers to search results
PROWLARR_URL=http://localhost:9696
PROWLARR_KEY=

# ━━━ TMDB (optional) ━━━
# Get your own key at: https://www.themoviedb.org/settings/api
# TMDB_KEY=your_key_here

# ━━━ Download Paths ━━━
# Must match qBittorrent category save paths
PATH_ANIME=/downloads/anime
PATH_MOVIES=/downloads/movies
PATH_SHOWS=/downloads/shows

# ━━━ Server ━━━
VM_PORT=7171
# VM_HOST=0.0.0.0
